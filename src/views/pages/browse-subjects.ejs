<%# Subject selection page for a selected branch and semester in the guided browse flow. %>
<section class="space-y-10">
  <header class="space-y-3">
    <a
      class="text-xs font-semibold uppercase tracking-wide text-neutral-600 hover:text-neutral-900"
      href="/browse/semester?branch=<%= encodeURIComponent(branch) %>"
    >Back to semesters</a>
    <p class="text-xs font-semibold uppercase tracking-[0.35em] text-neutral-600"><%= branch %> / S<%= semester %></p>
    <h1 class="text-3xl font-bold uppercase tracking-tight text-neutral-900 md:text-4xl">Choose subject</h1>
  </header>

  <% if (!subjects.length) { %>
    <div class="border border-neutral-900 bg-white p-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-neutral-700">No subjects available yet for this semester</p>
    </div>
  <% } else { %>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% for (const subject of subjects) { %>
        <article class="flex min-h-56 flex-col justify-between border border-neutral-900 bg-white p-5">
          <div class="space-y-3">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-neutral-500">Subject</p>
            <h2 class="text-xl font-bold uppercase tracking-tight text-neutral-900"><%= subject.subjectName %></h2>
            <p class="font-mono text-sm text-neutral-700"><%= subject.subjectCode %></p>
          </div>

          <div class="mt-8 grid gap-2 text-center text-xs font-semibold uppercase tracking-wide">
            <a
              class="border border-neutral-900 px-3 py-3 transition-colors hover:bg-neutral-900 hover:text-white"
              href="/browse/papers?branch=<%= encodeURIComponent(branch) %>&semester=<%= semester %>&subject=<%= encodeURIComponent(subject.subject) %>&type=MODEL"
            >Model papers</a>
            <a
              class="border border-neutral-900 px-3 py-3 transition-colors hover:bg-neutral-900 hover:text-white"
              href="/browse/papers?branch=<%= encodeURIComponent(branch) %>&semester=<%= semester %>&subject=<%= encodeURIComponent(subject.subject) %>&type=ENDSEM"
            >Previous sem papers</a>
          </div>
        </article>
      <% } %>
    </div>
  <% } %>
</section>
