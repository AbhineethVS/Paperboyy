<%# Admin form for creating or editing a manual answer on an existing question. %>
<section class="space-y-8">
  <header class="space-y-3">
    <a class="text-xs font-semibold uppercase tracking-wide text-neutral-600 hover:text-neutral-900" href="/admin">Back to admin</a>
    <p class="text-xs font-semibold uppercase tracking-[0.35em] text-neutral-600">Admin</p>
    <h1 class="text-3xl font-bold uppercase tracking-tight text-neutral-900 md:text-4xl"><%= form.heading %></h1>
  </header>

  <% if (error) { %>
    <div class="border border-neutral-900 bg-white p-4 text-sm font-semibold text-neutral-900">
      <%= error %>
    </div>
  <% } %>

  <% if (form.showForm) { %>
    <form class="space-y-5 border border-neutral-900 bg-white p-6" method="post" action="<%= form.action %>">
      <label class="block space-y-2">
        <span class="text-xs font-semibold uppercase tracking-wide text-neutral-600">Question ID</span>
        <input
          class="w-full border border-neutral-900 px-3 py-2 font-mono text-sm"
          name="questionId"
          type="text"
          value="<%= questionId %>"
          readonly
        />
      </label>

      <% if (question) { %>
        <div class="border border-neutral-900 p-3 text-sm text-neutral-700">
          <span class="block text-xs font-semibold uppercase tracking-wide text-neutral-500">Question</span>
          <p class="mt-1"><%= question.questionText %></p>
        </div>
      <% } %>

      <label class="block space-y-2">
        <span class="text-xs font-semibold uppercase tracking-wide text-neutral-600">Answer text</span>
        <textarea
          class="min-h-48 w-full border border-neutral-900 px-3 py-2 text-sm"
          name="answerText"
          required
        ><%= values.answerText || '' %></textarea>
      </label>

      <button
        class="border border-neutral-900 px-4 py-3 text-xs font-semibold uppercase tracking-wide transition-colors hover:bg-neutral-900 hover:text-white"
        type="submit"
      >
        <%= form.submitLabel %>
      </button>
    </form>
  <% } %>
</section>
