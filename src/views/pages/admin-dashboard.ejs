<%# Minimal admin dashboard for navigating manual question and answer entry tools. %>
<section class="space-y-8">
  <header class="space-y-3">
    <p class="text-xs font-semibold uppercase tracking-[0.35em] text-neutral-600">Admin</p>
    <h1 class="text-3xl font-bold uppercase tracking-tight text-neutral-900 md:text-4xl">Question tools</h1>
    <p class="max-w-2xl text-sm leading-relaxed text-neutral-700">
      Add questions and answers directly to existing papers. New entries show on the paper page immediately.
    </p>
  </header>

  <div class="grid gap-4 sm:grid-cols-2">
    <a
      class="border border-neutral-900 bg-white p-5 transition-colors hover:bg-neutral-900 hover:text-white"
      href="/admin/question/new"
    >
      <span class="block text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">Create</span>
      <span class="mt-4 block text-2xl font-bold uppercase tracking-tight">New question</span>
    </a>
  </div>
</section>
