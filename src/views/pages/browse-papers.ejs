<%# Paper list page for the final guided browse step, linking each paper into the question viewer. %>
<section class="space-y-10">
  <header class="space-y-3">
    <a
      class="text-xs font-semibold uppercase tracking-wide text-neutral-600 hover:text-neutral-900"
      href="/browse/subjects?branch=<%= encodeURIComponent(branch) %>&semester=<%= semester %>"
    >Back to subjects</a>
    <p class="text-xs font-semibold uppercase tracking-[0.35em] text-neutral-600">
      <%= branch %> / S<%= semester %> / <%= subject %>
    </p>
    <h1 class="text-3xl font-bold uppercase tracking-tight text-neutral-900 md:text-4xl"><%= paperTypeLabel %></h1>
  </header>

  <% if (!papers.length) { %>
    <div class="border border-neutral-900 bg-white p-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-neutral-700">
        No papers available yet (new scheme or not uploaded)
      </p>
    </div>
  <% } else { %>
    <div class="grid gap-4 sm:grid-cols-2">
      <% for (const paper of papers) { %>
        <% const displaySubjectName = paper.subjectName || paper.title || paper.subject || subject; %>
        <% const displayMonth = paper.month || 'Month not set'; %>
        <% const displayYear = paper.year || 'Year not set'; %>
        <article class="flex min-h-56 flex-col justify-between border border-neutral-900 bg-white p-5">
          <div class="space-y-3">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-neutral-500">Paper</p>
            <h2 class="text-xl font-bold uppercase tracking-tight text-neutral-900"><%= displaySubjectName %></h2>
            <dl class="grid grid-cols-2 gap-3 text-sm">
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Year</dt>
                <dd class="font-mono text-neutral-900"><%= displayYear %></dd>
              </div>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Month</dt>
                <dd class="font-mono text-neutral-900"><%= displayMonth %></dd>
              </div>
              <div class="col-span-2">
                <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Type</dt>
                <dd class="font-mono text-neutral-900"><%= paperTypeLabel %></dd>
              </div>
            </dl>
          </div>

          <div class="mt-8">
            <a
              class="inline-flex border border-neutral-900 px-4 py-3 text-xs font-semibold uppercase tracking-wide transition-colors hover:bg-neutral-900 hover:text-white"
              href="/paper/<%= paper._id %>"
            >Open paper</a>
          </div>
        </article>
      <% } %>
    </div>
  <% } %>
</section>
