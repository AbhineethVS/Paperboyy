<%# Admin password form for unlocking session-based access to manual admin tools. %>
<section class="mx-auto max-w-md space-y-8">
  <header class="space-y-3">
    <p class="text-xs font-semibold uppercase tracking-[0.35em] text-neutral-600">Admin</p>
    <h1 class="text-3xl font-bold uppercase tracking-tight text-neutral-900">Enter password</h1>
    <p class="text-sm leading-relaxed text-neutral-700">
      This unlocks the admin tools for the current browser session.
    </p>
  </header>

  <% if (error) { %>
    <div class="border border-neutral-900 bg-white p-4 text-sm font-semibold text-neutral-900">
      <%= error %>
    </div>
  <% } %>

  <form class="space-y-5 border border-neutral-900 bg-white p-6" method="post" action="/admin">
    <label class="block space-y-2">
      <span class="text-xs font-semibold uppercase tracking-wide text-neutral-600">Password</span>
      <input
        class="w-full border border-neutral-900 px-3 py-2 text-sm"
        name="password"
        type="password"
        required
        autofocus
      />
    </label>

    <button
      class="border border-neutral-900 px-4 py-3 text-xs font-semibold uppercase tracking-wide transition-colors hover:bg-neutral-900 hover:text-white"
      type="submit"
    >
      Unlock admin
    </button>
  </form>
</section>
