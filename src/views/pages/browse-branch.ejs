<%# Branch selection page for the first step of the guided browse flow. %>
<section class="space-y-10">
  <header class="space-y-3">
    <p class="text-xs font-semibold uppercase tracking-[0.35em] text-neutral-600">Browse archive</p>
    <h1 class="text-3xl font-bold uppercase tracking-tight text-neutral-900 md:text-4xl">Choose your branch</h1>
    <p class="max-w-2xl text-sm leading-relaxed text-neutral-700">
      Start with your branch, then narrow down by semester, subject, and paper type.
    </p>
  </header>

  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    <% for (const branch of branches) { %>
      <a
        href="/browse/semester?branch=<%= encodeURIComponent(branch) %>"
        class="group border border-neutral-900 bg-white p-5 transition-colors hover:bg-neutral-900 hover:text-white"
      >
        <span class="block text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500 group-hover:text-white">Branch</span>
        <span class="mt-5 block text-3xl font-bold uppercase tracking-tight"><%= branch %></span>
      </a>
    <% } %>
  </div>
</section>
